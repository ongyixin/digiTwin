GEMINI_API_KEY=AIza...

# Option A — Personal Access Token (simplest)
GITHUB_ACCESS_TOKEN=ghp_...

# Option B — GitHub App (for production/org-level access)
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_INSTALLATION_ID=

ENVIRONMENT=development

# ── RocketRide pipeline engine ─────────────────────────────────────────────
# Leave ROCKETRIDE_URI empty (or unset) to use the built-in in-process
# execution path. Set it to delegate all .pipe DAG execution to a running
# RocketRide engine instance.
#
#   Local engine (Docker Compose):   ws://localhost:5565
#   In-stack (backend container):    ws://rocketride-engine:5565
#   RocketRide Cloud:                wss://cloud.rocketride.ai
#
ROCKETRIDE_URI=ws://localhost:5565
ROCKETRIDE_APIKEY=digitwin-local
